# RX Shift — Environment Variable Template
# Copy this to .env.local and fill in real values.

# ─── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_jwt_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_jwt_key

# ─── Resend ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=hello@rxshift.io
CONTACT_TO_EMAIL=info@rxshift.io

# ─── OpenAI (in-product AI — server-side only) ─────────────────────────────────
OPENAI_API_KEY=sk-proj-your-key-here

# ─── Cron ──────────────────────────────────────────────────────────────────────
CRON_SECRET=generate-a-random-string

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3200
